APP_NAME=EncryptEd
APP_ENV=local
APP_KEY=base64:GENERATED_BY_PHP_ARTISAN_KEY_GENERATE
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Switch from SQLite to MySQL ──────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=encrypted_db
DB_USERNAME=root
DB_PASSWORD=

# ── Mail — SendGrid SMTP ─────────────────────────────────
# Sign up free at https://sendgrid.com → Settings → API Keys → Create
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=YOUR_SENDGRID_API_KEY_HERE
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@encrypted.edu.ph"
MAIL_FROM_NAME="EncryptEd"

# ── For LOCAL TESTING (no SendGrid key yet) ──────────────
# Use Mailpit (built into Laragon) or Mailtrap (free)
# Comment the SendGrid lines above and uncomment these:
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null
# Then visit http://localhost:8025 to see sent emails

# ── Session / Cache ──────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=true

CACHE_STORE=database
QUEUE_CONNECTION=database

# ── AES-256 Encryption Key for PII ──────────────────────
# This is Laravel's APP_KEY used by Crypt:: facade (AES-256-CBC)
# Run: php artisan key:generate   ← do this first after setup
